        <mxCell id="6YNjnEO0xa3laQHdsvQA-139" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontSize=9;" value="&lt;div&gt;&lt;b&gt;One-shot layer&lt;/b&gt; (&lt;i&gt;&lt;span style=&quot;color: light-dark(rgb(255, 0, 0), rgb(255, 0, 0));&quot;&gt;One Shot Keys&lt;/span&gt;&lt;/i&gt; type):&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Switch a layer On, but only for one keypress.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Once you press a key in the new layer, the layer is then deactivated. You can keep the layer active by holding the key down&lt;/div&gt;&lt;div&gt;&lt;i&gt;&lt;br&gt;&lt;/i&gt;&lt;/div&gt;&lt;div&gt;&lt;i&gt;Use &lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(0, 204, 0));&quot;&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(0, 204, 0));&quot;&gt;OSL(layer)&lt;/span&gt;&lt;/span&gt;&lt;/i&gt;&lt;/div&gt;" vertex="1">
