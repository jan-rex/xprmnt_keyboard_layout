        <mxCell id="6YNjnEO0xa3laQHdsvQA-151" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontSize=9;" value="&lt;div&gt;Direct switch &lt;b&gt;to&lt;/b&gt; a layer.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Works for switching to lower layers as well.&lt;/div&gt;&lt;div&gt;Turns on &quot;layer&quot; and turns off all other layers, except the default layer&lt;/div&gt;&lt;div&gt;&lt;i&gt;&lt;br&gt;&lt;/i&gt;&lt;/div&gt;&lt;div&gt;&lt;i&gt;Use &lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(0, 204, 0));&quot;&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(0, 204, 0));&quot;&gt;TO(layer)&lt;/span&gt;&lt;/span&gt;&lt;/i&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="280" x="239" y="3680" as="geometry" />
        </mxCell>
        <mxCell id="6YNjnEO0xa3laQHdsvQA-152" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontStyle=1;fontSize=18;" value="TT" vertex="1">
