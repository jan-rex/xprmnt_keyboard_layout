        <mxCell id="6YNjnEO0xa3laQHdsvQA-153" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontSize=9;" value="&lt;div&gt;&lt;b&gt;Layer Tap-Toggle&lt;/b&gt;:&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Normally acts like &lt;b&gt;&lt;span style=&quot;color: light-dark(rgb(255, 0, 0), rgb(255, 0, 0));&quot;&gt;MO&lt;/span&gt;&lt;/b&gt; unless it&#39;s tapped multiples times, which toggles layer On&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;If you hold the key down, the layer becomes active, and then deactivates when you let go.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;And if you tap it, the layer simply becomes active (toggles on).&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;i&gt;Use &lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(0, 204, 0));&quot;&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(0, 204, 0));&quot;&gt;TT(layer)&lt;/span&gt;&lt;/span&gt;&lt;/i&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="280" x="239" y="4080" as="geometry" />
        </mxCell>
